{
  "name": "html-ad-to-mp4",
  "version": "1.0.0",
  "private": true,
  "description": "Render HTML ads to MP4",
  "main": "render.js",
  "scripts": {
    "render": "node render.js",
    "placeholders": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-nursing-home-placeholders.ps1",
    "import:assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/import-nursing-home-assets.ps1",
    "build:scroll": "node scripts/build-scroll-feed.js",
    "build:logo": "node scripts/process-insider-logo.js"
  },
  "devDependencies": {
    "sharp": "^0.33.5"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "puppeteer": "^24.2.0"
  }
}
